{%- liquid
  assign products_count = section.settings.products_count
  if section.settings.collection != blank
    assign products = section.settings.collection.products
  else
    assign products = collections.all.products
  endif
-%}

<div class="hirot-product-grid">
  <div class="hirot-product-grid__header">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="hirot-section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hirot-section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.view_all_url != blank -%}
      <a href="{{ section.settings.view_all_url }}" class="hirot-btn hirot-btn--ghost hirot-btn--sm">すべて見る</a>
    {%- endif -%}
  </div>

  <div class="hirot-product-grid__grid">
    {%- for product in products limit: products_count -%}
      {%- liquid
        assign badge_tags = 'popular,new,20off,free-shipping,gift,limited' | split: ','
        assign badge_labels = '人気,新着,20%OFF,送料無料,ギフト対応,限定' | split: ','
        assign card_badge = blank
        for tag in product.tags
          assign tag_lower = tag | downcase | replace: ' ', '-'
          for b in badge_tags
            if tag_lower == b
              assign badge_index = forloop.index0
              assign card_badge = badge_labels[badge_index]
            endif
          endfor
        endfor

        assign rating = product.metafields.aoi.rating | times: 1.0
        assign review_count = product.metafields.aoi.review_count
        assign full_stars = rating | floor
        assign remainder = rating | minus: full_stars
        assign has_half = false
        if remainder >= 0.3
          assign has_half = true
        endif
        assign half_star_position = full_stars | plus: 1

        assign unsplash_ids = 'photo-1620916566398-39f1143ab7be,photo-1611930022073-b7a4ba5fcccd,photo-1598452963314-b09f397a5c48,photo-1608248543803-ba4f8c70ae0b,photo-1571781926291-c477ebfd024b,photo-1612817288484-6f916006741a,photo-1556228720-195a672e8a03,photo-1598440947619-2c35fc9aa908,photo-1596462502278-27bfdc403348,photo-1590439471364-192aa70c0b53,photo-1631730359585-38a4935cbec4,photo-1615397349754-cfa2066a298e' | split: ','
        assign img_index = forloop.index0 | modulo: 12
        assign fallback_id = unsplash_ids[img_index]
      -%}
      <a href="{{ product.url }}" class="hirot-card">
        <div class="hirot-card__image-wrap">
          {%- if product.featured_image != blank -%}
            {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title }}
          {%- else -%}
            <img src="https://images.unsplash.com/{{ fallback_id }}?w=800&q=80" alt="{{ product.title | escape }}" loading="lazy" width="800" height="1067">
          {%- endif -%}
          {%- if card_badge != blank -%}
            <span class="hirot-card__badge">{{ card_badge }}</span>
          {%- endif -%}
          {%- unless product.available -%}
            <span class="hirot-card__soldout-badge">売り切れ</span>
          {%- endunless -%}
        </div>
        <div class="hirot-card__info">
          <div class="hirot-card__brand">{{ shop.name | upcase }}</div>
          <div class="hirot-card__title">{{ product.title }}</div>
          {%- if rating > 0 -%}
            <div class="hirot-card__rating">
              {%- for i in (1..5) -%}
                {%- if i <= full_stars -%}
                  <span class="hirot-star hirot-star--full">★</span>
                {%- elsif has_half and i == half_star_position -%}
                  <span class="hirot-star hirot-star--half">★</span>
                {%- else -%}
                  <span class="hirot-star hirot-star--empty">★</span>
                {%- endif -%}
              {%- endfor -%}
              <span class="hirot-card__rating-score">{{ rating }}</span>
              {%- if review_count -%}
                <span class="hirot-card__rating-count">({{ review_count }})</span>
              {%- endif -%}
            </div>
          {%- endif -%}
          <div class="hirot-card__price-wrap">
            <span class="hirot-card__price">{{ product.price | money }}</span>
            {%- if product.compare_at_price > product.price -%}
              <span class="hirot-card__compare-price">{{ product.compare_at_price | money }}</span>
            {%- endif -%}
          </div>
          {%- comment -%} カード全体が a のため button は不可（HTML 不正）。実カート追加もしない飾りなので装飾 span にする {%- endcomment -%}
          <span class="hirot-card__btn" aria-hidden="true">カートに入れる</span>
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Hirot Product Grid",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "眉書き",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "人気のアイテム"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "コレクション"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "表示件数",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "すべて見る URL"
    }
  ],
  "presets": [
    {
      "name": "Hirot Product Grid"
    }
  ]
}
{% endschema %}
