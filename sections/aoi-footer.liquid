<footer class="aoi-footer">
  <div class="aoi-footer__inner">
    <div class="aoi-footer__top">
      <!-- Brand -->
      <div class="aoi-footer__brand">
        <a href="/" class="aoi-footer__logo">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 21c0-6 0-9 5-13-1 6-2 9-5 13Z" fill="var(--aoi-green-40)"/>
            <path d="M12 21c0-5-1-8-6-11 2 5 3 8 6 11Z" fill="var(--aoi-green-50)"/>
          </svg>
          <span class="aoi-footer__logo-text">{{ section.settings.store_name | default: shop.name }}</span>
        </a>
        <p class="aoi-footer__tagline">{{ section.settings.tagline }}</p>
      </div>

      <!-- Nav columns -->
      <nav class="aoi-footer__nav" aria-label="フッターナビゲーション">
        {%- for block in section.blocks -%}
          {%- if block.type == 'column' -%}
            <div class="aoi-footer__col" {{ block.shopify_attributes }}>
              <span class="aoi-footer__col-title">{{ block.settings.title }}</span>
              <ul class="aoi-footer__links">
                {%- assign linklist = linklists[block.settings.menu] -%}
                {%- if linklist.links.size > 0 -%}
                  {%- for link in linklist.links -%}
                    <li>
                      <a href="{{ link.url }}" class="aoi-footer__link">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                {%- else -%}
                  {%- if block.settings.link_1_label != blank -%}
                    <li><a href="{{ block.settings.link_1_url }}" class="aoi-footer__link">{{ block.settings.link_1_label }}</a></li>
                  {%- endif -%}
                  {%- if block.settings.link_2_label != blank -%}
                    <li><a href="{{ block.settings.link_2_url }}" class="aoi-footer__link">{{ block.settings.link_2_label }}</a></li>
                  {%- endif -%}
                  {%- if block.settings.link_3_label != blank -%}
                    <li><a href="{{ block.settings.link_3_url }}" class="aoi-footer__link">{{ block.settings.link_3_label }}</a></li>
                  {%- endif -%}
                  {%- if block.settings.link_4_label != blank -%}
                    <li><a href="{{ block.settings.link_4_url }}" class="aoi-footer__link">{{ block.settings.link_4_label }}</a></li>
                  {%- endif -%}
                {%- endif -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    </div>

    <div class="aoi-footer__bottom">
      <span class="aoi-footer__copy">© {{ 'now' | date: '%Y' }} {{ shop.name }}</span>
      <span class="aoi-footer__copy">
        {%- if shop.privacy_policy != blank -%}
          <a href="{{ shop.privacy_policy.url }}" class="aoi-footer__link">プライバシーポリシー</a> ・
        {%- endif -%}
        {%- if shop.refund_policy != blank -%}
          <a href="{{ shop.refund_policy.url }}" class="aoi-footer__link">返品ポリシー</a> ・
        {%- endif -%}
        {%- if shop.terms_of_service != blank -%}
          <a href="{{ shop.terms_of_service.url }}" class="aoi-footer__link">利用規約</a>
        {%- endif -%}
      </span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "aoi Footer",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "store_name",
      "label": "ストア名（ロゴテキスト）",
      "default": "aoi"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "タグライン",
      "default": "植物のちからで、素肌をととのえる。国産ボタニカル基礎化粧品ブランド。"
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "カラム",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "カラムタイトル",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "メニュー（未設定の場合は手動入力）"
        },
        {
          "type": "text",
          "id": "link_1_label",
          "label": "リンク1 テキスト",
          "default": "すべての商品"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "リンク1 URL",
          "default": "/collections/all"
        },
        {
          "type": "text",
          "id": "link_2_label",
          "label": "リンク2 テキスト"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "リンク2 URL"
        },
        {
          "type": "text",
          "id": "link_3_label",
          "label": "リンク3 テキスト"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "リンク3 URL"
        },
        {
          "type": "text",
          "id": "link_4_label",
          "label": "リンク4 テキスト"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "リンク4 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "aoi Footer",
      "blocks": [
        {
          "type": "column",
          "settings": {
            "title": "Shop",
            "link_1_label": "すべての商品",
            "link_1_url": "/collections/all",
            "link_2_label": "クレンジング",
            "link_2_url": "/collections/all",
            "link_3_label": "化粧水・美容液",
            "link_3_url": "/collections/all",
            "link_4_label": "ギフト・キット",
            "link_4_url": "/collections/all"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "About",
            "link_1_label": "ブランドについて",
            "link_1_url": "/pages/about",
            "link_2_label": "私たちの想い",
            "link_2_url": "/pages/about",
            "link_3_label": "お問い合わせ",
            "link_3_url": "/pages/contact"
          }
        },
        {
          "type": "column",
          "settings": {
            "title": "Support",
            "link_1_label": "配送について",
            "link_1_url": "/pages/contact",
            "link_2_label": "返品・交換",
            "link_2_url": "/pages/contact",
            "link_3_label": "アカウント",
            "link_3_url": "/account"
          }
        }
      ]
    }
  ]
}
{% endschema %}
