          "settings": {
            "label": "動物実験なし",
            "label_en": "CRUELTY-FREE",
            "color": "#bcd2e0",
            "icon": ""
          }
        },
        {
          "type": "value",
          "settings": {
            "label": "オーガニック認証",
            "label_en": "ORGANIC",
            "color": "#f0e4c8",
            "icon": ""
          }
        },
        {
          "type": "value",
          "settings": {
            "label": "環境への配慮",
            "label_en": "ECO-FRIENDLY",
            "color": "#e2c4b8",
            "icon": ""
          }
        }
      ]
