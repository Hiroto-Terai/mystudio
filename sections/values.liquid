
{%- style -%}
  .values-{{ section.id }} {
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  }
{%- endstyle -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section values values-{{ section.id }} section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {%- if section.settings.label != blank or section.settings.heading != blank -%}
    <div class="values__header reveal">
      {%- if section.settings.label != blank -%}
        <p class="values__label">{{ section.settings.label | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="values__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <ul class="values__grid" role="list">
      {%- for block in section.blocks -%}
        <li
          class="values__item reveal"
          style="--reveal-delay: {{ forloop.index0 | times: 0.1 }}s"
          {{ block.shopify_attributes }}
        >
          <div class="values__icon" style="--icon-color: {{ block.settings.color }}">
            {%- if block.settings.icon != blank -%}
              <span class="values__icon-text" aria-hidden="true">{{ block.settings.icon }}</span>
            {%- endif -%}
          </div>
          {%- if block.settings.label_en != blank -%}
            <p class="values__name-en">{{ block.settings.label_en | escape }}</p>
          {%- endif -%}
          {%- if block.settings.label != blank -%}
            <p class="values__name-jp">{{ block.settings.label | escape }}</p>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

{% stylesheet %}
  .values__header {
    text-align: center;
    margin-block-end: var(--margin-5xl, 3rem);
  }

  .values__label {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-block-end: 0.75rem;
  }

  .values__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 300;
    margin: 0;
  }

  .values__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .values__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.5rem;
    gap: 0.75rem;
    position: relative;
  }

  .values__item:not(:first-child) {
    border-inline-start: 1px solid var(--color-border);
  }

  .values__icon {
    width: 3.75rem;
    height: 3.75rem;
    border-radius: 50%;
    background-color: var(--icon-color, #e5d5c8);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-block-end: 0.5rem;
    flex-shrink: 0;
  }

  .values__icon-text {
    font-size: 1.5rem;
    line-height: 1;
  }

  .values__name-en {
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.6;
    margin: 0;
  }

  .values__name-jp {
    font-size: 0.875rem;
    opacity: 0.8;
    margin: 0;
  }

  /* Reveal animation */
  .values .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.6s ease var(--reveal-delay, 0s),
      transform 0.6s ease var(--reveal-delay, 0s);
  }

  .values .reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  /* Mobile: 2-column layout */
  @media screen and (width < 750px) {
    .values__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Reset border on items that become first in their row */
    .values__item:nth-child(3) {
      border-inline-start: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .values .reveal {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var sectionId = {{ section.id | json }};
    var sectionEl = document.querySelector('.values-' + sectionId);

    if (!sectionEl) return;

    var targets = sectionEl.querySelectorAll('.reveal');
    if (!targets.length) return;

    if (!window._revealObserver) {
      window._revealObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              window._revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
    }

    targets.forEach(function (el) {
      window._revealObserver.observe(el);
    });
  })();
</script>

{% schema %}
{
  "name": "Values",
  "class": "values-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "OUR VALUES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Botanicaが大切にすること"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label (JP)",
          "default": "価値観"
        },
