        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or character)",
          "default": "✓"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Values",
      "category": "t:categories.basic",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "label": "ヴィーガン対応",
            "label_en": "VEGAN",
            "color": "#c9dcc4",
            "icon": ""
          }
        },
        {
