<section class="hirot-philosophy">
  <div class="hirot-philosophy__inner">
    <div class="hirot-philosophy__image-wrap">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy' }}
      {%- else -%}
        <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=1000&q=80" alt="" width="1000" height="800" style="width:100%;height:100%;object-fit:cover;display:block">
      {%- endif -%}
    </div>

    <div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="hirot-section-eyebrow" style="color:var(--hirot-green-70)">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hirot-section-heading" style="margin:12px 0 16px">{{ section.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="hirot-philosophy__body">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url }}" class="hirot-btn hirot-btn--primary" style="height:44px">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hirot Philosophy Band",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "画像"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "眉書き",
      "default": "Our Philosophy"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "見出し",
      "default": "<p>肌本来の力を、<br>植物が引き出す。</p>"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "本文",
      "default": "私たちは、必要なものだけを選び抜いた処方にこだわります。国産のボタニカル成分と、余計なものを加えないシンプルなレシピで、敏感な肌にもやさしく寄り添います。"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "ボタン テキスト",
      "default": "ブランドストーリー"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "ボタン URL"
    }
  ],
  "presets": [
    {
      "name": "Hirot Philosophy Band"
    }
  ]
}
{% endschema %}
