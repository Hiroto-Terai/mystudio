
{%- style -%}
  .testimonials-{{ section.id }} {
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  }
{%- endstyle -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="testimonials testimonials-{{ section.id }} section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="testimonials__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="testimonials__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="testimonials__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <ul class="testimonials__list" role="list">
      {%- for block in section.blocks -%}
        <li class="testimonial" {{ block.shopify_attributes }}>
          {%- if block.settings.rating > 0 -%}
            <div
              class="testimonial__stars"
              aria-label="{{ block.settings.rating }} out of 5 stars"
            >
              {%- for i in (1..block.settings.rating) -%}★{%- endfor -%}
            </div>
          {%- endif -%}

          {%- if block.settings.quote != blank -%}
            <blockquote class="testimonial__quote">
              <p>{{ block.settings.quote | escape }}</p>
            </blockquote>
          {%- endif -%}

          <cite class="testimonial__author">
            {%- if block.settings.author_image != blank -%}
              <div class="testimonial__avatar">
                {{-
                  block.settings.author_image
                  | image_url: width: 80
                  | image_tag: loading: 'lazy', alt: block.settings.author_name
                -}}
              </div>
            {%- endif -%}
            <div class="testimonial__author-info">
              <span class="testimonial__name">{{ block.settings.author_name | escape }}</span>
              {%- if block.settings.author_title != blank -%}
                <span class="testimonial__title">{{ block.settings.author_title | escape }}</span>
              {%- endif -%}
            </div>
          </cite>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

<style>
  .testimonials__header {
    text-align: center;
    margin-block-end: var(--margin-xl);
  }

  .testimonials__heading {
    margin-block-end: var(--margin-sm);
  }

  .testimonials__subheading {
    opacity: 0.75;
  }

  .testimonials__list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-lg);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (width < 750px) {
    .testimonials__list {
      grid-template-columns: 1fr;
    }
  }

  .testimonial {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
    padding: var(--padding-xl);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
  }

  .testimonial__stars {
    color: #f59e0b;
    font-size: 1.125rem;
    letter-spacing: 0.05em;
  }

  .testimonial__quote {
    flex: 1;
    margin: 0;
    font-style: italic;
    line-height: 1.6;
  }

  .testimonial__author {
    display: flex;
    align-items: center;
    gap: var(--gap-sm);
    font-style: normal;
  }

  .testimonial__avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .testimonial__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial__author-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .testimonial__name {
    font-weight: 600;
  }

  .testimonial__title {
    font-size: 0.875rem;
    opacity: 0.65;
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "class": "testimonials-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review",
          "default": "This product completely transformed my skincare routine. My skin has never felt so smooth and hydrated."
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author title",
          "default": "Verified customer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "t:categories.basic",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "This moisturizer is absolutely incredible. My skin has never felt so soft and hydrated. I've tried so many products, but this one is a game changer.",
            "author_name": "Sarah M.",
            "author_title": "Verified customer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "I have sensitive skin and this is the first serum that hasn't caused any irritation. My skin tone is visibly more even after just two weeks.",
            "author_name": "Emily T.",
            "author_title": "Verified customer"
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "rating": 5,
            "quote": "Love that everything is natural and cruelty-free. You can really feel the difference with clean ingredients. My skin glows every morning.",
            "author_name": "Mia K.",
            "author_title": "Verified customer"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
