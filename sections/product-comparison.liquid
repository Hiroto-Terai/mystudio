
{%- style -%}
  .comparison-{{ section.id }} {
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  }
{%- endstyle -%}

{%- assign featured = section.settings.featured_column | times: 1 -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section comparison comparison-{{ section.id }} section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {%- if section.settings.label != blank or section.settings.heading != blank -%}
    <div class="comparison__header reveal">
      {%- if section.settings.label != blank -%}
        <p class="comparison__label">{{ section.settings.label | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="comparison__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="comparison__table-wrap reveal">
    <table class="comparison__table" role="table">
      <thead>
        <tr class="comparison__header-row">
          <th class="comparison__corner" scope="col" aria-label="特徴"></th>
          {%- for i in (1..3) -%}
            {%- assign name_key = 'p' | append: i | append: '_name' -%}
            {%- assign jp_key = 'p' | append: i | append: '_name_jp' -%}
            <th
              class="comparison__product-head{% if i == featured %} comparison__product-head--featured{% endif %}"
              scope="col"
            >
              {%- if i == featured -%}
                <span class="comparison__badge">RECOMMENDED</span>
              {%- endif -%}
              <span class="comparison__product-name">{{ section.settings[name_key] | escape }}</span>
              <span class="comparison__product-name-jp">{{ section.settings[jp_key] | escape }}</span>
            </th>
          {%- endfor -%}
        </tr>
      </thead>
      <tbody>
        {%- for block in section.blocks -%}
          <tr class="comparison__row" {{ block.shopify_attributes }}>
            <td class="comparison__row-label">{{ block.settings.label | escape }}</td>
            {%- assign vals = 'val1,val2,val3' | split: ',' -%}
            {%- for v in vals -%}
              {%- assign col = forloop.index -%}
              <td class="comparison__cell{% if col == featured %} comparison__cell--featured{% endif %}">
                {{- block.settings[v] | escape -}}
              </td>
            {%- endfor -%}
          </tr>
        {%- endfor -%}
        <tr class="comparison__row comparison__price-row">
          <td class="comparison__row-label"></td>
          {%- for i in (1..3) -%}
            {%- assign price_key = 'p' | append: i | append: '_price' -%}
            <td class="comparison__cell comparison__price{% if i == featured %} comparison__cell--featured comparison__price--featured{% endif %}">
              {{ section.settings[price_key] | escape }}
            </td>
          {%- endfor -%}
        </tr>
      </tbody>
    </table>
  </div>
</div>

{% stylesheet %}
  .comparison__header {
    text-align: center;
    margin-block-end: var(--margin-5xl, 3rem);
  }

  .comparison__label {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-block-end: 0.75rem;
  }

  .comparison__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 300;
    margin: 0;
  }

  .comparison__table-wrap {
    overflow-x: auto;
  }

  .comparison__table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .comparison__corner {
    width: 180px;
  }

  .comparison__product-head {
    text-align: center;
    padding: 1.5rem 1rem;
    vertical-align: top;
    position: relative;
  }

  .comparison__product-head--featured {
    background: rgba(182, 147, 122, 0.06);
  }

  .comparison__badge {
    display: inline-block;
    font-size: 0.5625rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #fff;
    background: #b6937a;
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
    margin-block-end: 0.75rem;
  }

  .comparison__product-name {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    font-weight: 500;
    color: #2b2b2b;
  }

  .comparison__product-name-jp {
    display: block;
    font-size: 0.75rem;
    opacity: 0.55;
    margin-block-start: 0.25rem;
  }

  .comparison__row {
    border-block-start: 1px solid var(--color-border);
  }

  .comparison__row-label {
    font-size: 0.8125rem;
    opacity: 0.65;
    padding: 1rem 0;
    text-align: start;
    width: 180px;
  }

  .comparison__cell {
    text-align: center;
    padding: 1rem;
    font-size: 0.875rem;
  }

  .comparison__cell--featured {
    background: rgba(182, 147, 122, 0.04);
    color: #b6937a;
    font-weight: 500;
  }

  .comparison__price-row {
    border-block-start: 1px solid var(--color-border);
  }

  .comparison__price {
    font-size: 1.125rem;
    font-weight: 300;
    padding-block: 1.25rem;
  }

  .comparison__price--featured {
    font-size: 1.25rem;
    color: #b6937a;
  }

  /* Reveal animation */
  .comparison .reveal {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.6s ease var(--reveal-delay, 0s),
      transform 0.6s ease var(--reveal-delay, 0s);
  }

  .comparison .reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  @media screen and (width < 750px) {
    .comparison__corner {
      width: 120px;
    }

    .comparison__row-label {
      width: 120px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .comparison .reveal {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var sectionId = {{ section.id | json }};
    var sectionEl = document.querySelector('.comparison-' + sectionId);

    if (!sectionEl) return;

    var targets = sectionEl.querySelectorAll('.reveal');
    if (!targets.length) return;

    if (!window._revealObserver) {
      window._revealObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              window._revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
    }

    targets.forEach(function (el) {
      window._revealObserver.observe(el);
    });
  })();
</script>

