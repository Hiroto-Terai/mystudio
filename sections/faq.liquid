
{%- style -%}
  .faq-section-{{ section.id }} {
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  }
{%- endstyle -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="faq-section faq-section-{{ section.id }} section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="faq-section__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="faq-section__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="faq-section__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="faq-section__list">
    {%- for block in section.blocks -%}
      <faq-item
        class="faq-item{% if block.settings.open_by_default %} faq-item--open{% endif %}"
        {{ block.shopify_attributes }}
      >
        <button
          class="faq-item__question"
          aria-expanded="{{ block.settings.open_by_default }}"
          aria-controls="faq-answer-{{ block.id }}"
          id="faq-question-{{ block.id }}"
        >
          <span class="faq-item__question-text">{{ block.settings.question | escape }}</span>
          <span class="faq-item__icon" aria-hidden="true">
            <span class="faq-item__icon-bar faq-item__icon-bar--h"></span>
            <span class="faq-item__icon-bar faq-item__icon-bar--v"></span>
          </span>
        </button>
        <div
          class="faq-item__answer"
          id="faq-answer-{{ block.id }}"
          role="region"
          aria-labelledby="faq-question-{{ block.id }}"
        >
          <div class="faq-item__answer-inner">
            {{ block.settings.answer }}
          </div>
        </div>
      </faq-item>
    {%- endfor -%}
  </div>
</div>

<style>
  .faq-section__header {
    margin-block-end: var(--margin-xl);
    text-align: center;
  }

  .faq-section__heading {
    margin-block-end: var(--margin-sm);
  }

  .faq-section__subheading {
    opacity: 0.75;
  }

  .faq-section__list {
    max-width: 48rem;
    margin-inline: auto;
    border-block-start: 1px solid var(--color-border);
  }

  .faq-item {
    display: block;
    border-block-end: 1px solid var(--color-border);
  }

  .faq-item__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
    width: 100%;
    padding-block: var(--padding-md);
    padding-inline: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: start;
    color: var(--color-foreground);
    font-size: var(--font-h5--size);
    font-weight: var(--font-h5--weight);
    font-family: var(--font-h5--family);
    line-height: var(--font-h5--line-height);
  }

  .faq-item__question:hover {
    opacity: 0.7;
  }

  .faq-item__icon {
    flex-shrink: 0;
    position: relative;
    width: 1.5rem;
    height: 1.5rem;
  }

  .faq-item__icon-bar {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    display: block;
    width: 1rem;
    height: 2px;
    background-color: currentColor;
    translate: -50% -50%;
    transition:
      scale var(--animation-speed) var(--ease-out-cubic),
      opacity var(--animation-speed) var(--ease-out-cubic);
  }

  .faq-item__icon-bar--v {
    rotate: 90deg;
  }

  .faq-item--open .faq-item__icon-bar--v {
    scale: 0;
    opacity: 0;
  }

  .faq-item__answer {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s var(--ease-out-cubic);
  }

  .faq-item--open .faq-item__answer {
    grid-template-rows: 1fr;
  }

  .faq-item__answer-inner {
    overflow: hidden;
    padding-block-end: 0;
    transition: padding-block-end 0.25s var(--ease-out-cubic);
  }

  .faq-item--open .faq-item__answer-inner {
    padding-block-end: var(--padding-md);
  }
</style>

<script>
  class FaqItem extends HTMLElement {
    connectedCallback() {
      this.button = this.querySelector('.faq-item__question');
      this.button.addEventListener('click', this.toggle.bind(this));
    }

    toggle() {
      const isOpen = this.classList.contains('faq-item--open');
      this.classList.toggle('faq-item--open');
      this.button.setAttribute('aria-expanded', String(!isOpen));
    }
  }

  if (!customElements.get('faq-item')) {
    customElements.define('faq-item', FaqItem);
  }
</script>

{% schema %}
{
  "name": "FAQ",
  "class": "faq-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your question?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Answer your customer's most common questions.</p>"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "category": "t:categories.basic",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day return policy on all items.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Standard shipping takes 3–5 business days.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer international shipping?",
            "answer": "<p>Yes, we ship to most countries worldwide.</p>"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
