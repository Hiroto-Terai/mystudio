{% doc %}
  Displays customer reviews for the current product from `customer_review` metaobjects.

  Expected metaobject definition (type: customer_review):
    - product (product reference)
    - rating  (integer, 1-5)
    - author  (single line text)
    - title   (single line text, optional)
    - body    (multi-line text)
    - date    (date, optional)
{% enddoc %}

{%- liquid
  assign reviews = shop.metaobjects.customer_review.values
  assign review_count = 0
  assign rating_sum = 0

  for review in reviews
    if review.product.value.id == product.id
      assign review_count = review_count | plus: 1
      assign rating_sum = rating_sum | plus: review.rating.value
    endif
  endfor

  assign average = 0
  if review_count > 0
    assign average = rating_sum | times: 1.0 | divided_by: review_count
  endif

  assign max_shown = section.settings.max_reviews
-%}

{%- if product != blank -%}
  <div
    class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    <div class="product-reviews page-width">
      <div class="product-reviews__header">
        <h2 class="product-reviews__heading">
          {{ section.settings.heading | default: 'content.reviews_title' | t }}
        </h2>

        {%- if review_count > 0 -%}
          <div class="product-reviews__summary">
            {% render 'rating-stars', rating: average, scale: 5 %}
            <span class="product-reviews__average">{{ average | round: 1 }} / 5</span>
            <span class="product-reviews__count">
              {{ 'content.reviews_count' | t: count: review_count }}
            </span>
          </div>
        {%- endif -%}
      </div>

      {%- if review_count > 0 -%}
        <ul class="product-reviews__list">
          {%- assign shown = 0 -%}
          {%- for review in reviews -%}
            {%- if review.product.value.id != product.id -%}
              {%- continue -%}
            {%- endif -%}
            {%- if shown >= max_shown -%}
              {%- break -%}
            {%- endif -%}
            {%- assign shown = shown | plus: 1 -%}
            <li class="product-reviews__item">
              <div class="product-reviews__item-head">
                {% render 'rating-stars', rating: review.rating.value, scale: 5 %}
                {%- if review.title != blank -%}
                  <span class="product-reviews__item-title">{{ review.title }}</span>
                {%- endif -%}
              </div>
              {%- if review.body != blank -%}
                <p class="product-reviews__item-body">{{ review.body }}</p>
              {%- endif -%}
              <p class="product-reviews__item-meta">
                {%- if review.author != blank -%}
                  <span class="product-reviews__item-author">{{ review.author }}</span>
                {%- endif -%}
                {%- if review.date != blank -%}
                  <span class="product-reviews__item-date">{{ review.date.value | date: '%Y.%m.%d' }}</span>
                {%- endif -%}
              </p>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p class="product-reviews__empty">{{ 'content.reviews_empty' | t }}</p>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .product-reviews__header {
    margin-block-end: var(--margin-2xl);
  }

  .product-reviews__heading {
    margin: 0 0 var(--margin-md);
  }

  .product-reviews__summary {
    display: flex;
    align-items: center;
    gap: var(--gap-sm, 0.7rem);
    font-size: var(--font-size--md);
  }

  .product-reviews__count {
    color: var(--color-foreground);
    opacity: 0.7;
  }

  .product-reviews__list {
    display: grid;
    gap: var(--gap-xl, 1.25rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .product-reviews__item {
    padding-block-end: var(--padding-lg);
    border-block-end: 1px solid var(--color-border);
  }

  .product-reviews__item-head {
    display: flex;
    align-items: center;
    gap: var(--gap-sm, 0.7rem);
    margin-block-end: var(--margin-xs);
  }

  .product-reviews__item-title {
    font-weight: var(--font-body--weight-bold, 600);
  }

  .product-reviews__item-body {
    margin: 0 0 var(--margin-sm);
  }

  .product-reviews__item-meta {
    display: flex;
    gap: var(--gap-md, 0.8rem);
    margin: 0;
    font-size: var(--font-size--sm);
    opacity: 0.7;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.product_reviews",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "レビュー"
    },
    {
      "type": "range",
      "id": "max_reviews",
      "label": "t:settings.max_reviews",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 10
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "t:names.product_reviews",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
