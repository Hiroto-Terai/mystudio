{%- comment -%}
  F5 最近見た商品（PDP 下部・related-products の後）。閲覧履歴は localStorage
  （キー nagi:recent）にしか無いため、一覧は assets/nagi-pdp.js の
  <nagi-recent-products> がクライアント側で描画する（F1 wishlist と同じ
  /products/<handle>.js フェッチ + .nagi-card 構造）。
  履歴 0 件（初訪問）や現商品しか無い場合は hidden のままセクションごと非表示。
{%- endcomment -%}
<nagi-recent-products
  class="nagi-recent"
  data-current-handle="{{ product.handle }}"
  data-brand="{{ shop.name | upcase }}"
  hidden
>
  <div class="nagi-recent__inner">
    <div class="nagi-recent__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nagi-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="nagi-section-heading">{{ section.settings.heading }}</h2>
    </div>
    <div class="nagi-recent__track" data-recent-track></div>
  </div>
</nagi-recent-products>
<script src="{{ 'nagi-pdp.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "最近見た商品",
  "tag": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "眉書き (英語)",
      "default": "Recently Viewed"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "最近見た商品"
    }
  ],
  "presets": [
    {
      "name": "最近見た商品"
    }
  ]
}
{% endschema %}
