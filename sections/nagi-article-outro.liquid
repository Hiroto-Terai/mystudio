{%- comment -%}
  記事末のアウトロ帯。ブランドからの一言と回遊リンク（読みもの一覧・商品）を置き、
  読み終わりを次の行動につなぐ。記事テンプレの関連商品カルーセルの前に配置する。
  JS ゼロ表示系（reveal 演出のみ nagi-motion.js）。
{%- endcomment -%}
<section
  class="nagi-outro"
  data-nagi-reveal
  style="--nagi-outro-pt: {{ section.settings.padding_top }}px; --nagi-outro-pb: {{ section.settings.padding_bottom }}px; background: {{ section.settings.background_color }};"
>
  <div class="nagi-outro__inner">
    {%- if section.settings.image != blank -%}
      <div class="nagi-outro__media">
        {{ section.settings.image | image_url: width: 640 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      </div>
    {%- endif -%}
    <div class="nagi-outro__body">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nagi-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nagi-outro__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="nagi-outro__text">{{ section.settings.body }}</p>
      {%- endif -%}
      <div class="nagi-outro__actions">
        {%- if section.settings.cta_1_label != blank -%}
          <a class="nagi-btn nagi-btn--primary" href="{{ section.settings.cta_1_url }}">{{ section.settings.cta_1_label }}</a>
        {%- endif -%}
        {%- if section.settings.cta_2_label != blank -%}
          <a class="nagi-btn nagi-btn--outline" href="{{ section.settings.cta_2_url }}">{{ section.settings.cta_2_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
<script src="{{ 'nagi-motion.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "記事アウトロ",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "画像（任意）" },
    { "type": "text", "id": "eyebrow", "label": "眉書き (英語)", "default": "From nagi" },
    { "type": "text", "id": "heading", "label": "見出し", "default": "素肌によりそう、次の一歩へ。" },
    { "type": "textarea", "id": "body", "label": "本文", "default": "読んでくださってありがとうございます。気になるアイテムや、ほかの読みものものぞいてみてください。あなたの毎日のお手入れが、少しでも心地よくなりますように。" },
    { "type": "text", "id": "cta_1_label", "label": "ボタン1 文言", "default": "アイテムを見る" },
    { "type": "url", "id": "cta_1_url", "label": "ボタン1 リンク" },
    { "type": "text", "id": "cta_2_label", "label": "ボタン2 文言", "default": "ほかの読みもの" },
    { "type": "url", "id": "cta_2_url", "label": "ボタン2 リンク" },
    { "type": "color", "id": "background_color", "label": "背景色", "default": "#f1fbf4" },
    { "type": "range", "id": "padding_top", "label": "上の余白", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "下の余白", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "presets": [
    { "name": "記事アウトロ" }
  ]
}
{% endschema %}
