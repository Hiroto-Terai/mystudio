
{%- style -%}
  .brand-story-{{ section.id }} {
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  }
{%- endstyle -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section brand-story brand-story-{{ section.id }} section--full-width color-{{ section.settings.color_scheme }}">
  <div class="brand-story__inner">
    <div class="brand-story__media reveal reveal--left">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            class: 'brand-story__image',
            sizes: '50vw',
            widths: '400,600,800,1000,1200,1400'
        }}
      {%- else -%}
        <div class="brand-story__placeholder">
          <span class="brand-story__placeholder-text">BOTANICA</span>
        </div>
      {%- endif -%}
    </div>

    <div class="brand-story__content reveal reveal--right">
      <p class="brand-story__eyebrow">
        <span class="brand-story__num">{{ section.settings.section_num | escape }}</span>
        <span class="brand-story__label">{{ section.settings.label | escape }}</span>
      </p>
      <div class="brand-story__accent-line" aria-hidden="true"></div>
      <h2 class="brand-story__heading">{{ section.settings.heading | escape }}</h2>
      <div class="brand-story__body">{{ section.settings.body }}</div>
      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <a href="{{ section.settings.cta_url }}" class="brand-story__cta">
          {{- section.settings.cta_label | escape -}}
          <span class="brand-story__cta-arrow" aria-hidden="true">→</span>
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .brand-story__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 640px;
  }

  .brand-story__media {
    position: relative;
    overflow: hidden;
  }

  .brand-story__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .brand-story__placeholder {
    width: 100%;
    height: 100%;
    min-height: 640px;
    background: #ede8e2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-story__placeholder-text {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.3em;
    user-select: none;
  }

  .brand-story__content {
    padding: clamp(3rem, 6vw, 6rem) clamp(2rem, 5vw, 5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .brand-story__eyebrow {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-block-end: 1.5rem;
  }

  .brand-story__num {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    color: #b6937a;
  }

  .brand-story__label {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.55;
  }

  .brand-story__accent-line {
    width: 1.75rem;
    height: 1px;
    background: #b6937a;
    margin-block-end: 2rem;
  }

  .brand-story__heading {
    font-size: clamp(1.75rem, 3vw, 2.75rem);
    font-weight: 300;
    line-height: 1.4;
    margin-block-end: 1.5rem;
  }

  .brand-story__body {
    font-size: 0.9375rem;
    line-height: 1.8;
    opacity: 0.7;
    margin-block-end: 2.5rem;
  }

  .brand-story__body p {
    margin-block-end: 1rem;
  }

  .brand-story__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #b6937a;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: gap 0.25s ease;
  }

  @media (any-pointer: fine) {
    .brand-story__cta:hover {
      gap: 0.75rem;
    }
  }

  .reveal {
    opacity: 0;
    transition:
      opacity 0.8s ease var(--reveal-delay, 0s),
      transform 0.8s ease var(--reveal-delay, 0s);
  }

  .reveal--left {
    transform: translateX(-30px);
  }

  .reveal--right {
    transform: translateX(30px);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  @media screen and (width < 750px) {
    .brand-story__inner {
      grid-template-columns: 1fr;
    }

    .brand-story__media {
      min-height: 320px;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    if (!window._revealObserver) {
      window._revealObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) e.target.classList.add('is-visible');
          });
        },
        { threshold: 0.15 }
      );
    }
    document.querySelectorAll('.brand-story-{{ section.id }} .reveal').forEach(function (el) {
      window._revealObserver.observe(el);
    });
  })();
</script>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "コンテンツ"
    },
    {
      "type": "text",
      "id": "section_num",
      "label": "セクション番号",
      "default": "03"
    },
    {
      "type": "text",
      "id": "label",
      "label": "ラベル",
      "default": "BRAND STORY"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "植物の力を、信じて。"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "本文",
      "default": "<p>Botanicaは、自然に存在する成分の力だけで、肌本来の美しさを引き出すことを目指しています。</p><p>創業以来、すべての製品においてオーガニック認証を取得した原料のみを使用し、人工香料や防腐剤を一切含まない透明なスキンケアをお届けしています。</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTAテキスト",
      "default": "ブランドについて"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTAリンク"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "画像"
    },
    {
      "type": "header",
      "content": "レイアウト"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラースキーム",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "余白"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "上の余白",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "下の余白",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Brand Story",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}
