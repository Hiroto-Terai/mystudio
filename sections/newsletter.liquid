
{%- style -%}
  .newsletter-{{ section.id }} {
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  }
{%- endstyle -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="newsletter newsletter-{{ section.id }} section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  <div class="newsletter__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="newsletter__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    {%- form 'customer', id: "newsletter-form-{{ section.id }}" -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      {%- if form.posted_successfully? -%}
        <p class="newsletter__success">{{ section.settings.success_message | escape }}</p>
      {%- else -%}
        <div class="newsletter__form">
          <label class="visually-hidden" for="newsletter-email-{{ section.id }}">
            {{ section.settings.placeholder | escape }}
          </label>
          <input
            class="newsletter__input"
            type="email"
            name="contact[email]"
            id="newsletter-email-{{ section.id }}"
            placeholder="{{ section.settings.placeholder | escape }}"
            autocomplete="email"
            required
          >
          <button class="newsletter__button" type="submit">
            {{ section.settings.button_label | escape }}
          </button>
        </div>
        {%- if form.errors -%}
          <p class="newsletter__error">
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </p>
        {%- endif -%}
      {%- endif -%}
    {%- endform -%}

    {%- if section.settings.disclaimer != blank -%}
      <p class="newsletter__disclaimer">{{ section.settings.disclaimer | escape }}</p>
    {%- endif -%}
  </div>
</div>

<style>
  .newsletter {
    text-align: center;
  }

  .newsletter__inner {
    max-width: 36rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--gap-lg);
  }

  .newsletter__heading,
  .newsletter__subheading {
    margin: 0;
  }

  .newsletter__subheading {
    opacity: 0.75;
  }

  .newsletter__form {
    display: flex;
    gap: var(--gap-sm);
    width: 100%;
  }

  @media screen and (width < 750px) {
    .newsletter__form {
      flex-direction: column;
    }
  }

  .newsletter__input {
    flex: 1;
    padding-block: 0.75rem;
    padding-inline: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    background: transparent;
    color: var(--color-foreground);
    font-size: 1rem;
    outline-offset: 2px;
  }

  .newsletter__input::placeholder {
    opacity: 0.5;
  }

  .newsletter__input:focus {
    outline: 2px solid var(--color-foreground);
  }

  .newsletter__button {
    padding-block: 0.75rem;
    padding-inline: 1.5rem;
    white-space: nowrap;
    cursor: pointer;
    border: none;
    font-size: 1rem;
    border-radius: 0.25rem;
    background-color: var(--color-foreground);
    color: var(--color-background);
    transition: opacity var(--animation-speed) var(--ease-out-cubic);
  }

  .newsletter__button:hover {
    opacity: 0.8;
  }

  .newsletter__success {
    color: var(--color-success);
    font-weight: 600;
    margin: 0;
  }

  .newsletter__error {
    color: var(--color-error);
    font-size: 0.875rem;
    margin: 0;
  }

  .newsletter__disclaimer {
    font-size: 0.8125rem;
    opacity: 0.55;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "class": "newsletter-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the ritual"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Subscribe for skincare tips, exclusive offers, and 10% off your first order."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for subscribing!"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "By subscribing you agree to our Privacy Policy."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-2"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "category": "t:categories.basic"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
