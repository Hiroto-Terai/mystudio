<section class="nagi-hero">
  <div class="nagi-hero__grid">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="nagi-section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h1 class="nagi-hero__heading">{{ section.settings.heading | replace: '<p>', '' | replace: '</p>', '' }}</h1>
      {%- if section.settings.body != blank -%}
        <p class="nagi-hero__body">{{ section.settings.body }}</p>
      {%- endif -%}
      <div class="nagi-hero__cta">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url }}" class="nagi-btn nagi-btn--primary nagi-btn--lg">
            {{ section.settings.cta_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url }}" class="nagi-btn nagi-btn--outline nagi-btn--lg">
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.image != blank -%}
      <div class="nagi-hero__image-wrap">
        {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'eager', fetchpriority: 'high' }}
      </div>
    {%- else -%}
      <div class="nagi-hero__image-wrap" style="background:var(--nagi-surface-wash)">
        <img src="https://images.unsplash.com/photo-1583209814683-c023dd293cc6?w=1000&q=80" alt="" width="1000" height="1250" style="width:100%;height:100%;object-fit:cover;display:block">
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Nagi Hero",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "眉書き (英語)",
      "default": "Botanical Skincare"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "見出し",
      "default": "<p>植物のちからで、<br>素肌をととのえる。</p>"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "本文",
      "default": "国産植物由来の成分を、やさしい処方で。毎日のスキンケアを、心地よい時間に変えていく。nagi の基礎化粧品。"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "ボタン1 テキスト",
      "default": "ストアを見る"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "ボタン1 URL"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "ボタン2 テキスト",
      "default": "ブランドについて"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "ボタン2 URL"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "ヒーロー画像"
    }
  ],
  "presets": [
    {
      "name": "Nagi Hero"
    }
  ]
}
{% endschema %}
