
{%- style -%}
  .ingredients-{{ section.id }} {
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  }
{%- endstyle -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section ingredients ingredients-{{ section.id }} section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {%- if section.settings.label != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="ingredients__header reveal">
      {%- if section.settings.label != blank -%}
        <p class="ingredients__label">{{ section.settings.label | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ingredients__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="ingredients__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <ul class="ingredients__grid" role="list">
      {%- for block in section.blocks -%}
        <li
          class="ingredient-card reveal"
          style="--dot-color: {{ block.settings.color }}"
          {{ block.shopify_attributes }}
        >
          <div class="ingredient-card__dot" aria-hidden="true"></div>
          <p class="ingredient-card__name">{{ block.settings.name | escape }}</p>
          <p class="ingredient-card__name-en">{{ block.settings.name_en | escape }}</p>
          <div class="ingredient-card__divider" role="separator"></div>
          <p class="ingredient-card__desc">{{ block.settings.description | escape }}</p>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

{% stylesheet %}
  .ingredients__header {
    text-align: center;
    margin-block-end: var(--margin-xl);
  }

  .ingredients__label {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-block-end: 0.75rem;
    margin-block-start: 0;
  }

  .ingredients__heading {
    font-weight: 300;
    font-size: var(--font-h2--size, 2.5rem);
    margin-block-start: 0;
    margin-block-end: 0;
  }

  .ingredients__subheading {
    font-size: 0.9375rem;
    opacity: 0.65;
    margin-block-start: 0.75rem;
    margin-block-end: 0;
    max-width: 36rem;
    margin-inline: auto;
    line-height: 1.7;
  }

  .ingredients__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (width < 750px) {
    .ingredients__grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (750px <= width < 990px) {
    .ingredients__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .ingredient-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 2px;
    padding: 1.75rem;
  }

  .ingredient-card__dot {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background-color: var(--dot-color, #e5d5c8);
    margin-block-end: 1.75rem;
  }

  .ingredient-card__name {
    font-size: 0.9375rem;
    font-weight: 500;
    margin-block-end: 0.35rem;
    margin-block-start: 0;
  }

  .ingredient-card__name-en {
    font-size: 0.625rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.55;
    margin-block-end: 1.25rem;
    margin-block-start: 0;
  }

  .ingredient-card__divider {
    height: 1px;
    background: var(--color-border);
    margin-block-end: 1.25rem;
  }

  .ingredient-card__desc {
    font-size: 0.8125rem;
    line-height: 1.7;
    opacity: 0.7;
    margin: 0;
  }

  /* Reveal animation */
  .ingredients .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.65s ease var(--reveal-delay, 0s),
      transform 0.65s ease var(--reveal-delay, 0s);
  }

  .ingredients .reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ingredients .reveal {
      opacity: 0;
      transform: translateY(20px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ingredients .reveal {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    if (!window._revealObserver) {
      window._revealObserver = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              window._revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15 }
      );
    }

    document
      .querySelectorAll('.ingredients-{{ section.id }} .reveal')
      .forEach(function (el, i) {
        el.style.setProperty('--reveal-delay', i * 0.08 + 's');
        window._revealObserver.observe(el);
      });
  })();
</script>

{% schema %}
