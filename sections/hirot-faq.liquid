{%- comment -%}
  F8 FAQ アコーディオン。metaobject `faq`（question / answer / sort）駆動。
  details/summary による JS ゼロの開閉 UI。
  metaobjects.faq.values は sort_by が使えないため、
  「ゼロ埋め相当の sort 値 + 元の添字」の文字列キーを sort して並び順を作る。
  values ドロップは整数インデックスアクセス非対応（values[0] も .first も nil）のため、
  描画側は sorted_keys × 全エントリの二重ループで添字を突き合わせて引き当てる（数件前提）。
{%- endcomment -%}
{%- liquid
  assign faq_entries = metaobjects.faq.values
  assign sort_keys = ''
  for entry in faq_entries
    assign padded_sort = entry.sort.value | plus: 100000
    assign sort_keys = sort_keys | append: padded_sort | append: '::' | append: forloop.index0 | append: ','
  endfor
  assign sorted_keys = sort_keys | split: ',' | sort
-%}

<div class="hirot-faq">
  <div class="hirot-faq__inner">
    <div class="hirot-faq__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="hirot-section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="hirot-section-heading">{{ section.settings.heading }}</h2>
    </div>

    {%- if faq_entries.size > 0 -%}
      <div class="hirot-faq__list">
        {%- for key in sorted_keys -%}
          {%- assign entry_index = key | split: '::' | last | plus: 0 -%}
          {%- for entry in faq_entries -%}
            {%- if forloop.index0 == entry_index and entry.question.value != blank -%}
              <details class="hirot-faq__item">
                <summary class="hirot-faq__question">
                  <span>{{ entry.question.value }}</span>
                  <svg class="hirot-faq__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                </summary>
                <div class="hirot-faq__answer">
                  <p>{{ entry.answer.value | newline_to_br }}</p>
                </div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "眉書き (英語)",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "よくあるご質問"
    }
  ],
  "presets": [
    {
      "name": "FAQ"
    }
  ]
}
{% endschema %}
