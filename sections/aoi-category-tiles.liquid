<section class="aoi-categories">
  <div class="aoi-categories__header">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="aoi-section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="aoi-section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  </div>

  <div class="aoi-categories__grid">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.url | default: '/collections/all' }}"
        class="aoi-tile"
        {{ block.shopify_attributes }}
      >
        <div class="aoi-tile__image-wrap">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="aoi-tile__title">{{ block.settings.label }}</div>
        {%- if block.settings.sub != blank -%}
          <div class="aoi-tile__sub">{{ block.settings.sub }}</div>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "aoi Category Tiles",
  "tag": "div",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "眉書き",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "カテゴリーから探す"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "カテゴリー",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "label",
          "label": "カテゴリー名",
          "default": "クレンジング"
        },
        {
          "type": "text",
          "id": "sub",
          "label": "サブテキスト",
          "default": "3アイテム"
        },
        {
          "type": "url",
          "id": "url",
          "label": "リンク先"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "aoi Category Tiles",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "label": "クレンジング",
            "sub": "洗顔・クレンジング"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "化粧水・美容液",
            "sub": "保湿・美白ケア"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "クリーム・オイル",
            "sub": "集中保湿ケア"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "ギフト・キット",
            "sub": "セットでお得"
          }
        }
      ]
    }
  ]
}
{% endschema %}
