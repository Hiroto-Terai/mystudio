
{%- style -%}
  .staff-introduction-{{ section.id }} {
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  }
{%- endstyle -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="staff-introduction staff-introduction-{{ section.id }} section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}"
>
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="staff-introduction__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="staff-introduction__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="staff-introduction__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- assign staff_members = shop.metaobjects.staff_member.values -%}
  {%- if staff_members != blank -%}
    <ul
      class="staff-introduction__grid"
      role="list"
      style="--staff-columns: {{ section.settings.columns }}"
    >
      {%- for member in staff_members -%}
        <li class="staff-card">
          {%- if member.photo.value != blank -%}
            <div class="staff-card__photo">
              {{-
                member.photo.value
                | image_url: width: 480
                | image_tag:
                  loading: 'lazy',
                  alt: member.name.value,
                  class: 'staff-card__image'
              -}}
            </div>
          {%- else -%}
            <div class="staff-card__photo staff-card__photo--placeholder">
              {{ 'image' | placeholder_svg_tag: 'staff-card__image staff-card__image--placeholder' }}
            </div>
          {%- endif -%}

          <div class="staff-card__info">
            {%- if member.name.value != blank -%}
              <p class="staff-card__name">{{ member.name.value | escape }}</p>
            {%- endif -%}
            {%- if member.role.value != blank -%}
              <p class="staff-card__role">{{ member.role.value | escape }}</p>
            {%- endif -%}
            {%- if member.bio.value != blank -%}
              <p class="staff-card__bio">{{ member.bio.value | escape }}</p>
            {%- endif -%}
            {%- if member.social_url.value != blank -%}
              <a
                class="staff-card__social"
                href="{{ member.social_url.value }}"
                target="_blank"
                rel="noopener noreferrer"
              >
                Follow
              </a>
            {%- endif -%}
          </div>
        </li>
      {%- endfor -%}
    </ul>
  {%- else -%}
    <p class="staff-introduction__empty">
      No staff members found. Add entries to the "Staff member" metaobject in your Shopify admin.
    </p>
  {%- endif -%}
</div>

<style>
  .staff-introduction__header {
    text-align: center;
    margin-block-end: var(--margin-xl);
  }

  .staff-introduction__heading {
    margin-block-end: var(--margin-sm);
  }

  .staff-introduction__subheading {
    opacity: 0.75;
  }

  .staff-introduction__grid {
    display: grid;
    grid-template-columns: repeat(var(--staff-columns, 3), 1fr);
    gap: var(--gap-lg);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (width < 750px) {
    .staff-introduction__grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (750px <= width < 1024px) {
    .staff-introduction__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .staff-introduction__empty {
    text-align: center;
    opacity: 0.6;
  }

  .staff-card {
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .staff-card__photo {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: 0.5rem;
    background-color: var(--color-border);
  }

  .staff-card__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .staff-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .staff-card__image--placeholder {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .staff-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .staff-card__name {
    font-weight: 600;
    font-size: 1.0625rem;
    margin: 0;
  }

  .staff-card__role {
    font-size: 0.875rem;
    opacity: 0.65;
    margin: 0;
  }

  .staff-card__bio {
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-block-start: 0.25rem;
    margin-block-end: 0;
  }

  .staff-card__social {
    display: inline-block;
    margin-block-start: 0.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .staff-card__social:hover {
    opacity: 0.7;
  }
</style>

{% schema %}
{
  "name": "Staff introduction",
  "class": "staff-introduction-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet our team"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Staff introduction",
      "category": "t:categories.basic"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  }
}
{% endschema %}
