{%- liquid
  assign products_count = section.settings.products_count
  if section.settings.collection != blank
    assign products = section.settings.collection.products
  else
    assign products = collections.all.products
  endif
-%}

<div class="nagi-product-grid">
  <div class="nagi-product-grid__header">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="nagi-section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nagi-section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
    {%- if section.settings.view_all_url != blank -%}
      <a href="{{ section.settings.view_all_url }}" class="nagi-btn nagi-btn--ghost nagi-btn--sm">すべて見る</a>
    {%- endif -%}
  </div>

  <div class="nagi-product-grid__grid">
    {%- for product in products limit: products_count -%}
      {%- liquid
        assign badge_tags = 'popular,new,20off,free-shipping,gift,limited' | split: ','
        assign badge_labels = '人気,新着,20%OFF,送料無料,ギフト対応,限定' | split: ','
        assign card_badge = blank
        for tag in product.tags
          assign tag_lower = tag | downcase | replace: ' ', '-'
          for b in badge_tags
            if tag_lower == b
              assign badge_index = forloop.index0
              assign card_badge = badge_labels[badge_index]
            endif
          endfor
        endfor

        assign rating = product.metafields.aoi.rating | times: 1.0
        assign review_count = product.metafields.aoi.review_count
        assign full_stars = rating | floor
        assign remainder = rating | minus: full_stars
        assign has_half = false
        if remainder >= 0.3
          assign has_half = true
        endif
        assign half_star_position = full_stars | plus: 1

        assign unsplash_ids = 'photo-1620916566398-39f1143ab7be,photo-1611930022073-b7a4ba5fcccd,photo-1598452963314-b09f397a5c48,photo-1608248543803-ba4f8c70ae0b,photo-1571781926291-c477ebfd024b,photo-1612817288484-6f916006741a,photo-1556228720-195a672e8a03,photo-1598440947619-2c35fc9aa908,photo-1596462502278-27bfdc403348,photo-1590439471364-192aa70c0b53,photo-1631730359585-38a4935cbec4,photo-1615397349754-cfa2066a298e' | split: ','
        assign img_index = forloop.index0 | modulo: 12
        assign fallback_id = unsplash_ids[img_index]
      -%}
      {%- comment -%} ハート（button）はカードリンクの兄弟に置く（a > button は HTML 不正）。カード全体を div 化しリンクと分離 {%- endcomment -%}
      <div class="nagi-card nagi-card--fav">
        <a href="{{ product.url }}" class="nagi-card__link">
          <div class="nagi-card__image-wrap">
            {%- if product.featured_image != blank -%}
              {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: product.title }}
            {%- else -%}
              <img src="https://images.unsplash.com/{{ fallback_id }}?w=800&q=80" alt="{{ product.title | escape }}" loading="lazy" width="800" height="1067">
            {%- endif -%}
            {%- if card_badge != blank -%}
              <span class="nagi-card__badge">{{ card_badge }}</span>
            {%- endif -%}
            {%- unless product.available -%}
              <span class="nagi-card__soldout-badge">売り切れ</span>
            {%- endunless -%}
          </div>
          <div class="nagi-card__info">
            <div class="nagi-card__brand">{{ shop.name | upcase }}</div>
            <div class="nagi-card__title">{{ product.title }}</div>
            {%- if rating > 0 -%}
              <div class="nagi-card__rating">
                {%- for i in (1..5) -%}
                  {%- if i <= full_stars -%}
                    <span class="nagi-star nagi-star--full">★</span>
                  {%- elsif has_half and i == half_star_position -%}
                    <span class="nagi-star nagi-star--half">★</span>
                  {%- else -%}
                    <span class="nagi-star nagi-star--empty">★</span>
                  {%- endif -%}
                {%- endfor -%}
                <span class="nagi-card__rating-score">{{ rating }}</span>
                {%- if review_count -%}
                  <span class="nagi-card__rating-count">({{ review_count }})</span>
                {%- endif -%}
              </div>
            {%- endif -%}
            <div class="nagi-card__price-wrap">
              <span class="nagi-card__price">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="nagi-card__compare-price">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
            {%- comment -%} リンク内のため button は不可（HTML 不正）。装飾 span だが「詳しく見る」はリンクの挙動説明として正しいので読み上げ対象に含める {%- endcomment -%}
            <span class="nagi-card__btn">詳しく見る</span>
          </div>
        </a>
        <nagi-fav-toggle data-product-handle="{{ product.handle }}"></nagi-fav-toggle>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Nagi Product Grid",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "眉書き",
      "default": "Featured"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "人気のアイテム"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "コレクション"
    },
    {
      "type": "range",
      "id": "products_count",
      "label": "表示件数",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "すべて見る URL"
    }
  ],
  "presets": [
    {
      "name": "Nagi Product Grid"
    }
  ]
}
{% endschema %}
