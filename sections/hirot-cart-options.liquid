{%- comment -%}
  F3 配送日時指定 + F7 ギフトラッピング（カートページの白パネル）。
  templates/cart.json で main-cart-footer の直前に配置し、footer 左カラム相当の
  幅（1.2fr / 1fr グリッドの左）に白パネルを置く。Dawn の main-cart-*.liquid は不改変。
  マークアップ本体はドロワーと共用の snippets/hirot-delivery.liquid にある。
{%- endcomment -%}
<div class="page-width">
  <div class="hirot-cart-options-grid">
    {%- render 'hirot-delivery',
      form_id: 'cart',
      context: 'page',
      id_suffix: section.id,
      exclude_sunday: section.settings.exclude_sunday,
      gift_price: section.settings.price,
      gift_note: section.settings.note
    -%}
  </div>
</div>
<script src="{{ 'hirot-cart.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "配送・ギフトオプション",
  "tag": "div",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "exclude_sunday",
      "label": "日曜日を配送日から除外する",
      "default": true
    },
    {
      "type": "number",
      "id": "price",
      "label": "ラッピング表示料金（円）",
      "info": "デモのため実課金はされません（cart attribute の記録のみ）",
      "default": 300
    },
    {
      "type": "text",
      "id": "note",
      "label": "ラッピング補足文",
      "default": "リボン付きの包装紙でお包みします。"
    }
  ],
  "presets": [
    {
      "name": "配送・ギフトオプション"
    }
  ]
}
{% endschema %}
