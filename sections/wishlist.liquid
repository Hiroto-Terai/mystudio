{%- liquid
  assign heading = section.settings.heading | default: 'content.wishlist_title' | t
-%}

<div
  class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="wishlist page-width">
    <h1 class="wishlist__heading">{{ heading }}</h1>

    <wishlist-list
      class="wishlist__list-wrapper"
      data-label-remove="{{ 'content.wishlist_remove' | t | escape }}"
      data-remove-icon="&times;"
    >
      <p class="wishlist__empty" data-wishlist-empty hidden>
        {{ 'content.wishlist_empty' | t }}
        {%- if section.settings.empty_link != blank -%}
          <a class="wishlist__empty-link" href="{{ section.settings.empty_link }}">
            {{ section.settings.empty_link_label | default: 'content.wishlist_empty_link' | t }}
          </a>
        {%- endif -%}
      </p>
      <ul class="wishlist__items" data-wishlist-items></ul>
    </wishlist-list>
  </div>
</div>

{% stylesheet %}
  .wishlist__heading {
    margin-block-end: var(--margin-2xl);
  }

  .wishlist__items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap-xl, 1.25rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media screen and (width >= 750px) {
    .wishlist__items {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .wishlist__item {
    position: relative;
  }

  .wishlist__card {
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm, 0.7rem);
    text-decoration: none;
    color: inherit;
  }

  .wishlist__media img {
    width: 100%;
    height: auto;
    border-radius: var(--style-border-radius-card, 0);
    object-fit: cover;
  }

  .wishlist__info {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xs, 0.125rem);
  }

  .wishlist__title {
    font-weight: var(--font-body--weight-bold, 600);
  }

  .wishlist__remove {
    position: absolute;
    top: var(--padding-xs, 0.5rem);
    right: var(--padding-xs, 0.5rem);
  }

  .wishlist__remove button {
    width: 2rem;
    height: 2rem;
    border: none;
    border-radius: 50%;
    background: var(--color-background);
    color: var(--color-foreground);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
  }

  .wishlist__empty {
    font-size: var(--font-size--lg);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.wishlist",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:settings.heading",
      "default": "Wishlist"
    },
    {
      "type": "url",
      "id": "empty_link",
      "label": "t:settings.wishlist_empty_link"
    },
    {
      "type": "text",
      "id": "empty_link_label",
      "label": "t:settings.wishlist_empty_link_label",
      "default": "Continue shopping"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "t:names.wishlist"
    }
  ]
}
{% endschema %}
