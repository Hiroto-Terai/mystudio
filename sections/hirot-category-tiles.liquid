<section class="hirot-categories">
  <div class="hirot-categories__header">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <span class="hirot-section-eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="hirot-section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  </div>

  <div class="hirot-categories__grid">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.url | default: '/collections/all' }}"
        class="hirot-tile"
        {{ block.shopify_attributes }}
      >
        <div class="hirot-tile__image-wrap">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
          {%- else -%}
            {%- case forloop.index0 -%}
              {%- when 0 -%}<img src="https://images.unsplash.com/photo-1620916566398-39f1143ab7be?w=600&q=80" alt="" width="600" height="600" style="width:100%;height:100%;object-fit:cover;display:block">
              {%- when 1 -%}<img src="https://images.unsplash.com/photo-1611930022073-b7a4ba5fcccd?w=600&q=80" alt="" width="600" height="600" style="width:100%;height:100%;object-fit:cover;display:block">
              {%- when 2 -%}<img src="https://images.unsplash.com/photo-1608248543803-ba4f8c70ae0b?w=600&q=80" alt="" width="600" height="600" style="width:100%;height:100%;object-fit:cover;display:block">
              {%- else -%}<img src="https://images.unsplash.com/photo-1612817288484-6f916006741a?w=600&q=80" alt="" width="600" height="600" style="width:100%;height:100%;object-fit:cover;display:block">
            {%- endcase -%}
          {%- endif -%}
        </div>
        <div class="hirot-tile__title">{{ block.settings.label }}</div>
        {%- if block.settings.sub != blank -%}
          <div class="hirot-tile__sub">{{ block.settings.sub }}</div>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Hirot Category Tiles",
  "tag": "div",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "眉書き",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "カテゴリーから探す"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "カテゴリー",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "label",
          "label": "カテゴリー名",
          "default": "クレンジング"
        },
        {
          "type": "text",
          "id": "sub",
          "label": "サブテキスト",
          "default": "3アイテム"
        },
        {
          "type": "url",
          "id": "url",
          "label": "リンク先"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hirot Category Tiles",
      "blocks": [
        {
          "type": "tile",
          "settings": {
            "label": "クレンジング",
            "sub": "洗顔・クレンジング"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "化粧水・美容液",
            "sub": "保湿・美白ケア"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "クリーム・オイル",
            "sub": "集中保湿ケア"
          }
        },
        {
          "type": "tile",
          "settings": {
            "label": "ギフト・キット",
            "sub": "セットでお得"
          }
        }
      ]
    }
  ]
}
{% endschema %}
