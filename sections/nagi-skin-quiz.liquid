{%- comment -%}
  肌診断クイズ。question ブロックの各選択肢に result_key を持たせ、
  result ブロックごとにおすすめ商品（コレクション）を Liquid で全部レンダーして
  hidden にしておく。JS（assets/nagi-motion.js の <nagi-skin-quiz>）は選んだキーを集計し、
  最多のキーに対応する result だけ表示する（クライアント集計・バックエンド不要）。
  JS 無効時は最初の質問がそのまま見える（進化的強化）。
{%- endcomment -%}
{%- liquid
  assign question_count = 0
  for block in section.blocks
    if block.type == 'question'
      assign question_count = question_count | plus: 1
    endif
  endfor
-%}
<nagi-skin-quiz
  class="nagi-quiz"
  data-nagi-reveal
  style="--nagi-quiz-pt: {{ section.settings.padding_top }}px; --nagi-quiz-pb: {{ section.settings.padding_bottom }}px; background: {{ section.settings.background_color }};"
>
  <div class="nagi-quiz__inner">
    <div class="nagi-quiz__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nagi-section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nagi-section-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.intro != blank -%}
        <p class="nagi-quiz__intro">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    <div class="nagi-quiz__progress">
      <span class="nagi-quiz__progress-bar" data-quiz-bar></span>
    </div>

    <div class="nagi-quiz__body">
      {%- assign qi = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          {%- assign qi = qi | plus: 1 -%}
          <fieldset
            class="nagi-quiz__step"
            data-quiz-step
            {% unless qi == 1 %}hidden{% endunless %}
            {{ block.shopify_attributes }}
          >
            <legend class="nagi-quiz__question">
              <span class="nagi-quiz__step-num">Q{{ qi }} / {{ question_count }}</span>
              {{ block.settings.question }}
            </legend>
            <div class="nagi-quiz__options">
              {%- for i in (1..4) -%}
                {%- assign label_key = 'option_' | append: i | append: '_label' -%}
                {%- assign key_key = 'option_' | append: i | append: '_key' -%}
                {%- assign opt_label = block.settings[label_key] -%}
                {%- if opt_label != blank -%}
                  <button
                    class="nagi-quiz__option"
                    type="button"
                    data-quiz-option
                    data-key="{{ block.settings[key_key] | escape }}"
                  >
                    {{ opt_label }}
                  </button>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </fieldset>
        {%- endif -%}
      {%- endfor -%}

      <div class="nagi-quiz__results" data-quiz-results hidden>
        {%- for block in section.blocks -%}
          {%- if block.type == 'result' -%}
            <div
              class="nagi-quiz__result"
              data-quiz-result
              data-key="{{ block.settings.result_key | escape }}"
              hidden
              {{ block.shopify_attributes }}
            >
              <div class="nagi-quiz__result-head">
                {%- if block.settings.eyebrow != blank -%}
                  <p class="nagi-section-eyebrow">{{ block.settings.eyebrow }}</p>
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h3 class="nagi-quiz__result-heading">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <p class="nagi-quiz__result-body">{{ block.settings.body }}</p>
                {%- endif -%}
              </div>
              {%- if block.settings.collection != blank -%}
                <div class="nagi-quiz__result-grid">
                  {%- for product in block.settings.collection.products limit: block.settings.products_count -%}
                    {% render 'nagi-product-card', product: product %}
                  {%- endfor -%}
                </div>
              {%- endif -%}
              <div class="nagi-quiz__result-actions">
                {%- if block.settings.cta_url != blank -%}
                  <a class="nagi-btn nagi-btn--primary" href="{{ block.settings.cta_url }}">
                    {{ block.settings.cta_label | default: 'コレクションを見る' }}
                  </a>
                {%- endif -%}
                <button class="nagi-quiz__restart" type="button" data-quiz-restart>もう一度診断する</button>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</nagi-skin-quiz>
<script src="{{ 'nagi-motion.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "肌診断クイズ",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "眉書き (英語)",
      "default": "Skin Quiz"
