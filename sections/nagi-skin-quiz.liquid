        { "type": "text", "id": "option_2_label", "label": "選択肢2 ラベル", "default": "テカり・毛穴" },
        { "type": "text", "id": "option_2_key", "label": "選択肢2 結果キー", "default": "oil" },
        { "type": "text", "id": "option_3_label", "label": "選択肢3 ラベル", "default": "ゆらぎ・敏感" },
        { "type": "text", "id": "option_3_key", "label": "選択肢3 結果キー", "default": "sensitive" },
        { "type": "text", "id": "option_4_label", "label": "選択肢4 ラベル" },
        { "type": "text", "id": "option_4_key", "label": "選択肢4 結果キー" }
      ]
    },
    {
      "type": "result",
      "name": "診断結果",
      "settings": [
        { "type": "text", "id": "result_key", "label": "結果キー", "default": "dry" },
        { "type": "text", "id": "eyebrow", "label": "眉書き (英語)", "default": "Your Result" },
        { "type": "text", "id": "heading", "label": "見出し", "default": "うるおいチャージが最優先" },
        { "type": "textarea", "id": "body", "label": "本文", "default": "水分を抱え込む処方で、乾いた肌をやさしく満たすアイテムを選びました。" },
        { "type": "collection", "id": "collection", "label": "おすすめコレクション" },
        { "type": "range", "id": "products_count", "label": "表示件数", "min": 2, "max": 8, "step": 1, "default": 3 },
        { "type": "text", "id": "cta_label", "label": "ボタン文言", "default": "コレクションを見る" },
        { "type": "url", "id": "cta_url", "label": "ボタンのリンク先" }
      ]
    }
  ],
  "presets": [
    {
      "name": "肌診断クイズ",
      "blocks": [
        {
          "type": "question",
          "settings": {
            "question": "いまの肌悩みに一番近いのは？",
            "option_1_label": "乾燥・かさつき", "option_1_key": "dry",
            "option_2_label": "テカり・毛穴", "option_2_key": "oil",
