{%- style -%}
  .how-to-{{ section.id }} {
    padding-block-start: {{ section.settings['padding-block-start'] }}px;
    padding-block-end: {{ section.settings['padding-block-end'] }}px;
  }
{%- endstyle -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section how-to how-to-{{ section.id }} section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }}">

  {%- if section.settings.label != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="how-to__header reveal">
      {%- if section.settings.label != blank -%}
        <p class="how-to__label">{{ section.settings.label | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="how-to__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="how-to__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="how-to__steps">
      <div class="how-to__connector" aria-hidden="true"></div>
      {%- for block in section.blocks -%}
        <div
          class="how-to__step reveal"
          style="--reveal-delay: {{ forloop.index0 | times: 0.12 }}s"
          {{ block.shopify_attributes }}
        >
          <div class="how-to__circle">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', class: 'how-to__image' }}
            {%- else -%}
              <div class="how-to__circle-bg" style="--circle-color: {{ block.settings.color }}"></div>
            {%- endif -%}
          </div>
          <p class="how-to__step-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</p>
          {%- if block.settings.title_en != blank -%}
            <p class="how-to__step-en">{{ block.settings.title_en | escape }}</p>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="how-to__step-title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="how-to__step-desc">{{ block.settings.description | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% stylesheet %}
  .how-to__header {
    text-align: center;
    margin-block-end: 3rem;
  }

  .how-to__label {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.6;
    margin-block-end: 1rem;
  }

  .how-to__heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 300;
    line-height: 1.3;
    margin-block-end: 0.75rem;
  }

  .how-to__subheading {
    font-size: 0.9375rem;
    line-height: 1.7;
    opacity: 0.65;
    max-width: 36rem;
    margin-inline: auto;
  }

  .how-to__steps {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding-block-start: 1rem;
  }

  .how-to__connector {
    position: absolute;
    top: calc(var(--circle-size, 10rem) / 2);
    left: calc(100% / 6);
    right: calc(100% / 6);
    height: 1px;
    background: var(--color-border);
    z-index: 0;
  }

  .how-to__step {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
  }

  .how-to__circle {
    width: var(--circle-size, 10rem);
    height: var(--circle-size, 10rem);
    border-radius: 50%;
    overflow: hidden;
    margin-block-end: 1.5rem;
    position: relative;
  }

  .how-to__circle-bg {
    width: 100%;
    height: 100%;
    background-color: var(--circle-color, #e5d5c8);
    opacity: 0.6;
  }

  .how-to__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .how-to__step-num {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    color: #b6937a;
    margin-block-end: 0.25rem;
  }

  .how-to__step-en {
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.7;
    margin-block-end: 0.25rem;
  }

  .how-to__step-title {
    font-size: 1.25rem;
    font-weight: 400;
    margin-block-end: 0.75rem;
  }

  .how-to__step-desc {
    font-size: 0.8125rem;
    line-height: 1.75;
    opacity: 0.65;
    max-width: 18rem;
  }

  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.65s ease var(--reveal-delay, 0s), transform 0.65s ease var(--reveal-delay, 0s);
  }

  .reveal.is-visible {
    opacity: 1;
    transform: none;
  }

  @media screen and (width < 750px) {
    .how-to__steps {
      grid-template-columns: 1fr;
    }

    .how-to__connector {
      display: none;
    }
  }
{% endstylesheet %}

<script>
  (function() {
    if (!window._revealObserver) {
      window._revealObserver = new IntersectionObserver(
        function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) e.target.classList.add('is-visible');
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
    }
    document.querySelectorAll('.how-to-{{ section.id }} .reveal').forEach(function(el) {
      window._revealObserver.observe(el);
    });
  })();
</script>

{% schema %}
{
  "name": "How To",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "header",
      "content": "コンテンツ"
    },
    {
      "type": "text",
      "id": "label",
      "label": "ラベル",
      "default": "HOW TO USE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "見出し",
      "default": "3ステップ スキンケアルーティン"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブテキスト",
      "default": "お肌の状態に合わせた、毎日のスキンケアルーティン。"
    },
    {
      "type": "header",
      "content": "レイアウト"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "セクション幅",
      "options": [
        { "value": "page-width", "label": "標準" },
        { "value": "full-width", "label": "全幅" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラースキーム",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "余白"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "上の余白",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "下の余白",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "ステップ",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "タイトル（日本語）",
          "default": "洗顔"
        },
        {
          "type": "text",
          "id": "title_en",
          "label": "タイトル（英語）",
          "default": "CLEANSE"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "説明文",
          "default": "朝晩2回、肌の汚れと過剰な皮脂をやさしく落とします。"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像（任意）"
        },
        {
          "type": "color",
          "id": "color",
          "label": "サークルカラー（画像なしの場合）",
          "default": "#e2c4b8"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How To",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "洗顔",
            "title_en": "CLEANSE",
            "description": "朝晩2回、肌の汚れと過剰な皮脂をやさしく落とします。",
            "color": "#e2c4b8"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "化粧水",
            "title_en": "TONE",
            "description": "洗顔後すぐにうるおいを補給し、肌を整えます。",
            "color": "#bcd2e0"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "保湿",
            "title_en": "MOISTURIZE",
            "description": "化粧水で整えた後、乳液やクリームで水分と油分のバランスを整えます。",
            "color": "#c9dcc4"
          }
        }
      ]
    }
  ]
}
{% endschema %}
