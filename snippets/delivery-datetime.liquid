{% doc %}
  Delivery date and time-slot picker for the cart page.
  Selections are stored as cart attributes and carried through to the order.
{% enddoc %}

{%- liquid
  assign date_key = 'content.delivery_date_attribute' | t
  assign time_key = 'content.delivery_time_attribute' | t

  assign lead_seconds = settings.delivery_lead_days | times: 86400
  assign min_date = 'now' | date: '%s' | plus: lead_seconds | date: '%Y-%m-%d'

  assign time_slots = settings.delivery_time_slots | strip | newline_to_br | split: '<br />'

  assign current_date = cart.attributes[date_key]
  assign current_time = cart.attributes[time_key]
-%}

<script src="{{ 'delivery-datetime.js' | asset_url }}" defer></script>

<delivery-datetime
  class="delivery-datetime"
  data-date-key="{{ date_key | escape }}"
  data-time-key="{{ time_key | escape }}"
  data-saved-text="{{ 'content.delivery_saved' | t | escape }}"
>
  <p class="delivery-datetime__title h6">{{ 'content.delivery_title' | t }}</p>

  <div class="delivery-datetime__field">
    <label class="delivery-datetime__label" for="delivery-date">
      {{ 'content.delivery_date_label' | t }}
    </label>
    <input
      type="date"
      id="delivery-date"
      class="delivery-datetime__input"
      data-delivery-date
      min="{{ min_date }}"
      value="{{ current_date | escape }}"
    >
  </div>

  {%- if time_slots.size > 0 -%}
    <div class="delivery-datetime__field">
      <label class="delivery-datetime__label" for="delivery-time">
        {{ 'content.delivery_time_label' | t }}
      </label>
      <select
        id="delivery-time"
        class="delivery-datetime__input"
        data-delivery-time
      >
        <option value="">{{ 'content.delivery_time_placeholder' | t }}</option>
        {%- for slot in time_slots -%}
          {%- assign slot_value = slot | strip -%}
          {%- unless slot_value == blank -%}
            <option value="{{ slot_value | escape }}" {% if slot_value == current_time %}selected{% endif %}>
              {{ slot_value }}
            </option>
          {%- endunless -%}
        {%- endfor -%}
      </select>
    </div>
  {%- endif -%}

  <span class="delivery-datetime__status" data-delivery-status role="status" aria-live="polite"></span>
</delivery-datetime>

{% stylesheet %}
  .delivery-datetime {
    display: block;
    margin-block-start: var(--margin-xl);
    padding: var(--padding-lg);
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-inputs, 0.4rem);
  }

  .delivery-datetime__title {
    margin: 0 0 var(--margin-md);
  }

  .delivery-datetime__field {
    display: flex;
    flex-direction: column;
    gap: var(--gap-2xs, 0.3rem);
    margin-block-end: var(--margin-md);
  }

  .delivery-datetime__field:last-of-type {
    margin-block-end: 0;
  }

  .delivery-datetime__input {
    width: 100%;
    padding: var(--padding-sm) var(--padding-md);
    background: var(--color-input-background);
    color: var(--color-input-text);
    border: 1px solid var(--color-input-border);
    border-radius: var(--style-border-radius-inputs, 0.4rem);
    font-size: var(--font-size--sm);
  }

  .delivery-datetime__status {
    display: block;
    margin-block-start: var(--margin-xs);
    font-size: var(--font-size--xs);
    color: var(--color-success);
  }
{% endstylesheet %}
