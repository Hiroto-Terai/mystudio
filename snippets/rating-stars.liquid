{% doc %}
  Renders a star rating. Supports decimals for averages via a clipped overlay.

  @param {number} rating - The rating value (e.g. 4 or 4.5)
  @param {number} [scale] - The maximum rating. Defaults to 5.
{% enddoc %}

{%- liquid
  assign stars_scale = scale | default: 5
  assign stars = ''
  for i in (1..stars_scale)
    assign stars = stars | append: '★'
  endfor
-%}

<span
  class="rating-stars"
  style="--rating: {{ rating | default: 0 }}; --rating-scale: {{ stars_scale }};"
  role="img"
  aria-label="{{ 'content.rating_aria' | t: rating: rating, scale: stars_scale }}"
>
  <span class="rating-stars__track" aria-hidden="true">{{ stars }}</span>
  <span class="rating-stars__fill" aria-hidden="true">{{ stars }}</span>
</span>

{% stylesheet %}
  .rating-stars {
    position: relative;
    display: inline-block;
    line-height: 1;
    white-space: nowrap;
  }

  .rating-stars__track {
    color: var(--color-border);
  }

  .rating-stars__fill {
    position: absolute;
    top: 0;
    left: 0;
    overflow: hidden;
    width: calc(var(--rating) / var(--rating-scale) * 100%);
    color: #f5a623;
  }
{% endstylesheet %}
