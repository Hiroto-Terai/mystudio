

{%- liquid
  assign is_on_sale = false
  if product.compare_at_price > product.price and product.available
    assign is_on_sale = true
  endif

  assign is_new = false
  if settings.badge_new_days > 0 and product.available
    assign new_window_seconds = settings.badge_new_days | times: 86400
    assign now_seconds = 'now' | date: '%s' | plus: 0
    assign published_seconds = product.published_at | date: '%s' | plus: 0
    assign time_diff = now_seconds | minus: published_seconds
    if time_diff <= new_window_seconds
      assign is_new = true
    endif
  endif

  assign is_low_stock = false
  if settings.badge_low_stock_threshold > 0 and product.available
    assign tracked_inventory = 0
    assign has_tracked_variant = false
    for variant in product.variants
      if variant.inventory_management
        assign has_tracked_variant = true
        assign tracked_inventory = tracked_inventory | plus: variant.inventory_quantity
      endif
    endfor
    if has_tracked_variant and tracked_inventory > 0 and tracked_inventory <= settings.badge_low_stock_threshold
      assign is_low_stock = true
    endif
  endif
-%}

<div class="product-badges product-badges--{{ settings.badge_position }}">
  {%- if product.available == false -%}
    <span class="product-badges__badge product-badges__badge--sold-out">
      {{ 'content.product_badge_sold_out' | t }}
    </span>
  {%- else -%}
    {%- if is_on_sale -%}
      <span class="product-badges__badge product-badges__badge--sale">
        {{ 'content.product_badge_sale' | t }}
      </span>
    {%- endif -%}
    {%- if is_new -%}
      <span class="product-badges__badge product-badges__badge--new">
        {{ 'content.product_badge_new' | t }}
      </span>
    {%- endif -%}
    {%- if is_low_stock -%}
      <span class="product-badges__badge product-badges__badge--low-stock">
        {{ 'content.product_badge_low_stock' | t }}
      </span>
    {%- endif -%}
  {%- endif -%}
</div>

{% stylesheet %}
  .product-badges {
    position: absolute;
    z-index: var(--layer-flat);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
  }

  .product-badges--top-left {
    top: 0.75rem;
    left: 0.75rem;
  }

  .product-badges--top-right {
    top: 0.75rem;
    right: 0.75rem;
    align-items: flex-end;
  }

  .product-badges--bottom-left {
    bottom: 0.75rem;
    left: 0.75rem;
  }

  .product-badges__badge {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1;
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(4px);
  }

  .product-badges__badge--sold-out {
    color: rgba(0, 0, 0, 0.4);
  }

  .product-badges__badge--sale {
    color: #b05a50;
  }

  .product-badges__badge--new {
    color: #4d7a62;
  }

  .product-badges__badge--low-stock {
    color: #a07030;
  }
{% endstylesheet %}
