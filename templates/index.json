    "how_to_section": {
      "type": "how-to",
      "blocks": {
        "step_1": {
          "type": "step",
          "settings": {
            "title": "洗顔",
            "title_en": "CLEANSE",
            "description": "ぬるま湯で顔を濡らし、泡立てたクレンザーで優しく洗い流します。",
            "color": "#c4d8e8"
          }
        },
        "step_2": {
          "type": "step",
          "settings": {
            "title": "化粧水",
            "title_en": "TONE",
            "description": "化粧水を手のひらにとり、顔全体にやさしく押し込むように馴染ませます。",
            "color": "#e8c4b8"
          }
        },
        "step_3": {
          "type": "step",
          "settings": {
            "title": "保湿",
            "title_en": "MOISTURIZE",
            "description": "モイスチャライザーを指先で温めてから、顔の中心から外側へ向けて丁寧に塗布します。",
            "color": "#c4dcc8"
          }
        }
      },
      "block_order": [
        "step_1",
        "step_2",
        "step_3"
      ],
      "name": "使い方",
