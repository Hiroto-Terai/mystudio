    "ingredients_section": {
      "type": "ingredients",
      "blocks": {
        "ingredient_1": {
          "type": "ingredient",
          "settings": {
            "name": "ローズヒップオイル",
            "name_en": "ROSEHIP OIL",
            "color": "#e8c8c0",
            "description": "ビタミンCとトランスレチノイン酸を豊富に含む天然オイル。肌の再生を促し、シミやくすみを改善します。"
          }
        },
        "ingredient_2": {
          "type": "ingredient",
          "settings": {
            "name": "ヒアルロン酸",
            "name_en": "HYALURONIC ACID",
            "color": "#c8d8e8",
            "description": "自重の1000倍以上の水分を保持する保湿成分。肌の奥から潤いを与え、ふっくらとしたハリをもたらします。"
          }
        },
        "ingredient_3": {
          "type": "ingredient",
          "settings": {
            "name": "グリーンティー",
            "name_en": "GREEN TEA EXTRACT",
            "color": "#c8d8c8",
            "description": "カテキンをはじめとする強力な抗酸化物質を含む緑茶エキス。紫外線ダメージから肌を守り、炎症を鎮静します。"
          }
        },
        "ingredient_4": {
          "type": "ingredient",
          "settings": {
            "name": "シアバター",
            "name_en": "SHEA BUTTER",
            "color": "#e8e0c8",
            "description": "脂肪酸とビタミンEが豊富な植物性バター。深く浸透して乾燥を防ぎ、肌のバリア機能を強化します。"
          }
        },
        "ingredient_5": {
          "type": "ingredient",
          "settings": {
            "name": "ナイアシンアミド",
            "name_en": "NIACINAMIDE",
            "color": "#e0d0e8",
            "description": "毛穴の目立ちを改善し、肌のトーンを均一に整えるビタミンB3誘導体。皮脂コントロールにも効果的です。"
          }
        }
      },
      "block_order": [
        "ingredient_1",
        "ingredient_2",
        "ingredient_3",
        "ingredient_4",
        "ingredient_5"
      ],
