<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  <head>
    {{ 'base.css' | asset_url | stylesheet_tag }}
    {{ 'aoi.css' | asset_url | stylesheet_tag }}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >

    {%- render 'meta-tags' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% comment %} aoi botanical — global color + font overrides (must be after color-schemes) {% endcomment %}
    {% style %}
      :root,
      .color-scheme-1,
      .color-1 {
        --color-background: #fbfbf5;
        --color-foreground: #0e100f;
        --color-foreground-heading: #0e100f;
        --color-border: #e8e8e1;
        --color-shadow: #0e100f;
        --color-primary-button-background: #0e100f;
        --color-primary-button-text: #ffffff;
        --color-primary-button-border: #0e100f;
        --color-primary-button-hover-background: #38383a;
        --color-primary-button-hover-text: #ffffff;
        --color-primary-button-hover-border: #38383a;
        --color-secondary-button-text: #0e100f;
        --color-secondary-button-background: transparent;
        --color-secondary-button-border: #0e100f;
        --color-secondary-button-hover-text: #ffffff;
        --color-secondary-button-hover-background: #0e100f;
        --color-secondary-button-hover-border: #0e100f;
        --color-input-background: #ffffff;
        --color-input-text: #0e100f;
        --color-input-border: #e8e8e1;
        --color-input-hover-background: #f1fbf4;
        --style-border-radius-inputs: 8px;
        --style-border-radius-buttons-primary: 9999px;
        --style-border-radius-buttons-secondary: 9999px;
        --font-body--family: "Noto Sans JP", "Hanken Grotesk", system-ui, sans-serif;
        --font-heading--family: "Hanken Grotesk", "Noto Sans JP", system-ui, sans-serif;
        --font-subheading--family: "Hanken Grotesk", "Noto Sans JP", system-ui, sans-serif;
        --font-accent--family: "Noto Sans JP", "Hanken Grotesk", system-ui, sans-serif;
      }
      body {
        background: #fbfbf5;
        color: #0e100f;
        font-family: "Noto Sans JP", "Hanken Grotesk", system-ui, sans-serif;
      }
    {% endstyle %}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
  </head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% # theme-check-disable ParserBlockingScript %}
    <script src="{{ 'critical.js' | asset_url }}"></script>
    {% # theme-check-enable ParserBlockingScript %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}

  </body>
</html>
